            "parameters": {
                "functionCode": "const pdfBinary = $input.item.binary.data;\n\n// Simulated AI OCR processing\n// In production, replace with HTTP Request to AI OCR service\n\nconst extractedText = \"{{FULL_TEXT_FROM_AI_OCR_NODE}}\";\n\nreturn [{\n  json: {\n    ocr_text: extractedText\n  },\n  binary: {\n    data: pdfBinary\n  }\n}];"
            },
