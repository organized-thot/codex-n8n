            "name": "AI OCR Node",
            "type": "n8n-nodes-base.function",
            "typeVersion": 2,
            "position": [
                600,
                300
            ]
        },
        {
            "parameters": {
                "functionCode": "const text = $json.ocr_text;\n\n// Simulated AI Document Analyzer\n// Replace with LLM API call for structural boundary detection\n\nlet resultFlag = \"Single Document\";\n\nif (text.includes(\"===NEW_DOCUMENT===\") || text.split(\"Page\").length > 5) {\n  resultFlag = \"Multi-Document\";\n}\n\nreturn [{\n  json: {\n    ocr_text: text,\n    document_type: resultFlag\n  },\n  binary: $binary\n}];"
            },
            "id": "4",
            "name": "AI Document Analyzer Node",
            "type": "n8n-nodes-base.function",
            "typeVersion": 2,
            "position": [
                800,
                300
            ]
        },
    {
        "parameters": {
            "conditions": {
                "string": [
                    {
                        "value1": "={{$json[\"document_type\"]}}",
                        "operation": "equal",
                        "value2": "Single Document"
                    },
                    {
                        "value1": "={{$json[\"document_type\"]}}",
                        "operation": "equal",
                        "value2": "Multi-Document"
                    }
                ]
            }
        },
