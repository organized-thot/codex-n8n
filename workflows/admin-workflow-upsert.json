        "jsCode": "const status = $json.statusCode ?? 0;\nif (status >= 400) {\n  return [{ json: { ok: false, apiError: true, statusCode: status, body: $json.body ?? null } }];\n}\n\nconst original = $items('IF Payload Valid', 0, 0)[0]?.json ?? {};\nconst records = $json.body?.data ?? [];\nconst target = records.find((w) => w?.name === original.requestName);\n\nconst workflowPayload = { ...original.workflowJson, name: original.requestName };\nif (original.activeProvided) workflowPayload.active = original.requestedActive;\n\nreturn [{\n  json: {\n    ok: true,\n    exists: Boolean(target?.id),\n    existingWorkflowId: target?.id ?? null,\n    requestName: original.requestName,\n    workflowPayload\n  }\n}];"
