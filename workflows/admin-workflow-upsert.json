        "jsCode": "const headerSecret = $json.headers?.['x-mobile-secret'] ?? $json.headers?.['X-Mobile-Secret'] ?? '';\nconst expectedSecret = $env.MOBILE_WEBHOOK_SECRET ?? '';\nconst body = $json.body ?? {};\n\nconst hasName = typeof body.name === 'string' && body.name.trim().length > 0;\nconst hasWorkflowJson = body.workflowJson && typeof body.workflowJson === 'object' && !Array.isArray(body.workflowJson);\nconst wf = hasWorkflowJson ? body.workflowJson : {};\nconst hasNodes = Array.isArray(wf.nodes);\nconst hasConnections = wf.connections && typeof wf.connections === 'object' && !Array.isArray(wf.connections);\nconst hasSettings = wf.settings && typeof wf.settings === 'object' && !Array.isArray(wf.settings);\n\nconst payloadValid = hasName && hasWorkflowJson && hasNodes && hasConnections && hasSettings;\n\nreturn [{\n  json: {\n    headerSecret,\n    expectedSecret,\n    authorized: Boolean(expectedSecret) && headerSecret === expectedSecret,\n    payloadValid,\n    payloadError: payloadValid ? null : 'invalid_payload',\n    requestName: hasName ? body.name.trim() : '',\n    workflowJson: hasWorkflowJson ? body.workflowJson : {},\n    activeProvided: typeof body.active === 'boolean',\n    requestedActive: body.active\n  }\n}];"
