        "jsCode": "const status = $json.statusCode ?? 0;\nif (status >= 400) {\n  return [{ json: { ok: false, error: 'n8n_api_error', statusCode: status, details: $json.body ?? null } }];\n}\nconst id = $json.body?.id ?? $json.body?.data?.id ?? null;\nreturn [{\n  json: {\n    ok: Boolean(id),\n    action: 'updated',\n    workflowId: id,\n    editorUrl: id ? `https://n8n.ermine-zebra.ts.net/workflow/${id}` : null\n  }\n}];"
