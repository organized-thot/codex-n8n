          }
        ]
      ]
    },
    "File Management Node (Backup Original PDF)": {
      "main": [
        [
          {
            "node": "AI Document Splitter Node (Detect Page Ranges)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "AI Document Splitter Node (Detect Page Ranges)": {
      "main": [
        [
          {
