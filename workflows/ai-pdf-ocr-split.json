            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Segments to Items": {
      "main": [
        [
          {
            "node": "Item Loop (Split in Batches)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Item Loop (Split in Batches)": {
      "main": [
        [
          {
