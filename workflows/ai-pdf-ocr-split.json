            "index": 0
          }
        ],
        [
          {
            "node": "Summarize Split Results",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Extract Page Range (qpdf)": {
      "main": [
        [
          {
            "node": "Record Segment Result",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Record Segment Result": {
      "main": [
        [
          {
